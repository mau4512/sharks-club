# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Desarrollo local. Produccion y staging tienen plantillas separadas:
# - .env.production.example
# - .env.staging.example
DATABASE_URL="postgresql://faraday:faraday_password@localhost:5433/faraday_basketball"
DIRECT_URL="postgresql://faraday:faraday_password@localhost:5433/faraday_basketball"

# NextAuth
NEXTAUTH_SECRET="faraday_local_secret_change_if_needed"
NEXTAUTH_URL="http://localhost:3000"

# Admin principal (login unificado)
# Usa SIEMPRE hash bcrypt en PRIMARY_ADMIN_PASSWORD_HASH
PRIMARY_ADMIN_EMAIL=""
PRIMARY_ADMIN_PASSWORD_HASH=""

# Solo para migración de contraseñas (no usar en runtime de producción)
PRIMARY_ADMIN_PASSWORD=""
