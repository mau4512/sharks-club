# Staging/pruebas: usar un proyecto Supabase separado, nunca la base real.
# Copia este contenido en las variables de entorno del hosting de preview/staging.

DATABASE_URL="postgresql://prisma.[PROJECT-REF-STAGING]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF-STAGING].supabase.co:5432/postgres"

NEXTAUTH_SECRET="[SECRET-LARGO-STAGING-DIFERENTE-A-PRODUCCION]"
NEXTAUTH_URL="https://staging.tudominio.com"

# Admin principal opcional. Usar siempre hash bcrypt.
PRIMARY_ADMIN_EMAIL=""
PRIMARY_ADMIN_PASSWORD_HASH=""
